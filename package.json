{
  "name": "rts-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen-sfx-manifest": "node -e \"const fs=require('fs'),p='public/sounds/sfx';fs.writeFileSync('public/sounds/sfx-manifest.json',JSON.stringify(fs.readdirSync(p).filter(f=>f.endsWith('.mp3')).map(f=>f.replace('.mp3','')).sort()))\"",
    "build": "npm run gen-sfx-manifest && vite build",
    "serve": "node server.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "bitecs": "^0.3.40",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
